{
  "log": {
    "disabled": false,
    "level": "info",
    "output": "box.log",
    "timestamp": true
  },
  "experimental": {
    "clash_api": {
      "external_controller": "192.168.6.1:9090",
      "external_ui": "ui",
      "secret": "123",
      "external_ui_download_url": "https://gh-proxy.com/https://github.com/MetaCubeX/Yacd-meta/archive/gh-pages.zip",
      "external_ui_download_detour": "direct"
    },
    "cache_file": {
      "enabled": false,
      "store_fakeip": false
    }
  },
  "ntp": {
    "enabled": true,
    "server": "ntp.aliyun.com",
    "interval": "60m"
  },
  "dns": {
    "servers": [
       {
        "tag": "dns_proxy_doh",
        "type": "https",
        "server": "dns.google",
        "domain_resolver": "dns_proxy",
        "detour": "Proxy"
      },
      {
        "type": "udp",
        "tag": "dns_proxy",
        "server": "1.1.1.1",
        "detour": "Proxy"
      },
      {
        "tag": "dns_direct_doh",
        "type": "https",
        "server": "dns.alidns.com",
        "domain_resolver": "dns_direct"
      },
      {
        "type": "udp",
        "tag": "dns_direct",
        "server": "223.5.5.5"
      }
    ],
    "rules": [
      {
        "source_ip_cidr": ["192.168.6.96/27", "192.168.6.128/26", "192.168.6.192/28"],
        "server": "dns_direct_doh"
      },
      {
        "clash_mode": "direct",
        "server": "dns_direct_doh"
      },
      {
        "clash_mode": "global",
        "server": "dns_proxy_doh"
      },
      {
        "rule_set": ["geosite-cn", "geosite-steamcn"],
        "server": "dns_direct_doh"
      },
      {
        "rule_set": "geolocation-!cn",
        "server": "dns_proxy_doh"
      }
    ],
    "strategy": "prefer_ipv4",
    "final": "dns_direct_doh",
    "client_subnet": "223.166.199.10",
    "disable_cache": false,
    "disable_expire": false,
    "independent_cache": false
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "tun0",
      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "mtu": 9000,
      "auto_route": true,
      "auto_redirect": true,
      "strict_route": true,
      "sniff": true,
      "stack": "mixed"
    }
  ],
  "outbounds": [
    {
      "tag":"Proxy",
      "type":"selector",
      "outbounds":[
        "America",
        "auto",
        "direct",
        "HongKong",
        "Others",
        "{all}"
      ]
    },
    {
      "tag":"America",
      "type":"urltest",
      "outbounds":[
        "{all}"
      ],
      "filter":[
        {"action":"include","keywords":["🇺🇸|US|us|美国|美|United States"]}
      ],
      "url": "http://www.gstatic.com/generate_204",
      "interval": "30m",
      "tolerance": 50
    },
    {
      "tag":"HongKong",
      "type":"selector",
      "outbounds":[
        "{all}"
      ],
      "filter":[
        {"action":"include","keywords":["🇭🇰|HK|hk|香港|港|HongKong"]}
      ]
    },
    {
      "tag":"Others",
      "type":"selector",
      "outbounds":[
        "{all}"
      ],
      "filter":[
        {"action":"exclude","keywords":["🇭🇰|HK|hk|香港|港|HongKong|🇺🇸|US|us|美国|美|United States"]}
      ]
    },
    {
      "tag":"auto",
      "type":"urltest",
      "outbounds":[
        "{all}"
      ],
      "filter":[
        {"action":"exclude","keywords":["网站|流量|地址|剩余|过期|时间|有效"]}
      ],
      "url": "http://www.gstatic.com/generate_204",
      "interval": "30m",
      "tolerance": 50
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "final": "direct",
    "default_domain_resolver": {
      "server": "dns_direct_doh"
    },
    "rules": [
      {"action": "sniff"},
      {
        "type": "logical", 
        "mode": "or", 
        "rules": [
          {"port": 53}, 
          {"protocol": "dns"}], 
        "action": "hijack-dns"
      },
      {
        "ip_is_private": true, 
        "outbound": "direct"
      },
      {
        "source_ip_cidr": ["192.168.6.96/27", "192.168.6.128/26", "192.168.6.192/28"],
        "outbound": "direct"
      },
      {
        "clash_mode": "direct",
        "outbound": "direct"
      },
      {
        "clash_mode": "global",
        "outbound": "Proxy"
      },
      {
        "domain": [
          "clash.razord.top",
          "yacd.metacubex.one",
          "yacd.haishan.me",
          "d.metacubex.one"
        ],
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-bilibili",
        "outbound": "direct"
      },
      {
        "rule_set": "geosite-steamcn",
        "outbound": "direct"
      },
      {
        "rule_set": [
          "geosite-myownrule",
          "geosite-steam",
          "geosite-youtube",
          "geosite-google",
          "geosite-github",
          "geoip-google"
        ],
        "outbound": "Proxy"
      },
      {
        "rule_set": [
          "geosite-cn",
          "geoip-cn"
        ],
        "outbound": "direct"
      },
      {
        "rule_set": "geolocation-!cn",
        "outbound": "Proxy"
      }
    ],
    "rule_set": [
      {
        "tag": "geosite-myownrule",
        "type": "remote",
        "format": "binary",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/Emental/myownfileset/main/geo/geosite/rule.srs",
        "download_detour": "direct",
        "update_interval": "24h"
      },
      {
        "tag": "geosite-youtube",
        "type": "remote",
        "format": "binary",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/youtube.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geoip-google",
        "type": "remote",
        "format": "binary",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geoip/google.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geosite-google",
        "type": "remote",
        "format": "binary",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/google.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geosite-github",
        "type": "remote",
        "format": "binary",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/github.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geosite-bilibili",
        "type": "remote",
        "format": "binary",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/bilibili.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geosite-steamcn", 
        "type": "remote", 
        "format": "binary", 
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/steam@cn.srs", 
        "download_detour": "direct"
      },
      {
        "tag": "geosite-steam", 
        "type": "remote", 
        "format": "binary", 
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/steam.srs", 
        "download_detour": "direct"
      },
      {
        "tag": "geolocation-!cn",
        "type": "remote",
        "format": "binary",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/geolocation-!cn.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geoip-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geoip/cn.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geosite-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://gh-proxy.com/https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/sing/geo/geosite/cn.srs",
        "download_detour": "direct"
      }
    ]
  }
}